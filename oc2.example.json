{
  "$schema": "https://oc2.ai/config.json",

  "username": "your-name",
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "deepseek/deepseek-v4-pro",
  "default_agent": "build",
  "shell": "/bin/zsh",
  "logLevel": "INFO",
  "autoupdate": "notify",
  "snapshot": true,
  "instructions": ["AGENTS.md", "docs/style.md"],
  "formatter": false,
  "lsp": true,

  "skills": {
    "paths": [".oc2/skills", "/abs/path/to/skills"],
    "urls": ["https://example.com/.well-known/skills/"]
  },

  "agent": {
    "build": { "disable": false },
    "plan": { "disable": false },
    "general": { "disable": false },
    "explore": { "disable": false },
    "my-reviewer": {
      "description": "Reviews PRs for style violations.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "high",
      "hidden": false,
      "color": "red",
      "temperature": 0.2,
      "top_p": 0.9,
      "steps": 50,
      "disable": false,
      "options": { "reasoning_effort": "high" },
      "permission": { "edit": "deny", "bash": "ask" },
      "prompt": "You are a strict PR reviewer. Focus on..."
    },
    "research-bot": {
      "description": "Read-only research subagent.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "permission": "allow",
      "prompt": "Research the codebase and report findings."
    }
  },

  "command": {
    "deploy": {
      "description": "Deploy the current project.",
      "prompt": "Run the deploy script and verify the rollout."
    },
    "release-notes": {
      "description": "Generate release notes from recent commits.",
      "prompt": "Summarize commits since the last tag."
    }
  },

  "provider": {
    "anthropic": { "options": { "apiKey": "sk-ant-..." } },
    "openai": { "options": { "apiKey": "sk-..." } },
    "deepseek": { "options": { "apiKey": "{env:DEEPSEEK_API_KEY}" } }
  },
  "enabled_providers": ["anthropic", "openai", "deepseek"],
  "disabled_providers": ["koboldcpp"],

  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "env": { "BROWSER": "chromium" }
    },
    "github": {
      "type": "remote",
      "url": "https://mcp.github.example.com/sse",
      "enabled": true,
      "headers": { "Authorization": "Bearer {env:GITHUB_TOKEN}" }
    },
    "old-server": { "enabled": false }
  },

  "plugin": [
    "opencode-gemini-auth",
    "opencode-foo@1.2.3",
    "./local-plugin.ts",
    "file:///abs/path/plugin.js",
    ["opencode-bar", { "option": "value" }]
  ],

  "permission": {
    "edit": "ask",
    "bash": { "git *": "allow", "rm *": "deny", "*": "ask" },
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "ask",
    "websearch": "allow",
    "lsp": "allow",
    "skill": "allow",
    "external_directory": { "~/secrets/**": "deny", "~/projects/**": "allow", "*": "ask" }
  },

  "tool_output": { "max_lines": 200, "max_bytes": 8192 },

  "compaction": { "auto": true, "tail_turns": 15 },

  "experimental": {
    "primary_tools": ["edit"],
    "mcp_timeout": 30000,
    "agent_teams": true,
    "openTelemetry": false
  },

  "fugu": {
    "branches": [
      { "model": "deepseek/deepseek-v4-pro", "variant": "high" },
      { "model": "openai/gpt-5.5", "variant": "high" }
    ],
    "synthesizer": { "model": "openai/gpt-5.5", "variant": "xhigh" }
  },

  "local_fusion": {
    "research": {
      "branches": [
        { "model": "deepseek/deepseek-v4-pro", "variant": "high", "toolPolicy": "all", "timeout": 120000 },
        { "model": "openai/gpt-5.5", "variant": "high", "toolPolicy": "all", "agent": "explore" }
      ],
      "judge": { "model": "openai/gpt-5.5", "variant": "high", "toolPolicy": "readonly" },
      "synthesizer": { "model": "openai/gpt-5.5", "variant": "xhigh", "toolPolicy": "none" }
    }
  }
}
