{
  "name": "oc2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "oc2": "./src/index.ts"
  },
  "oc2": {
    "opencodeReference": {
      "repo": "https://github.com/panwar-stack/opencode.git",
      "commit": "fa3477d6a3f94c86a85028bb6ab59a9fe731a686",
      "version": "1.16.2"
    }
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "start": "bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "bun run format && oxlint -c oxlint.json --import-plugin --report-unused-disable-directives src test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run typecheck && bun run format:check && oxlint -c oxlint.json --import-plugin --report-unused-disable-directives src test && bun test",
    "diagnostics": "bun run typecheck && bun run lint && bun run format:check && bun test",
    "smoke:tui": "bun run start tui --model fake/test"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.9",
    "@types/bun": "1.3.13",
    "oxlint": "1.60.0",
    "prettier": "3.6.2",
    "typescript": "5.8.2"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120,
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": false,
    "trailingComma": "all",
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "dependencies": {
    "@opentui/core": "0.3.4",
    "@opentui/keymap": "0.3.4",
    "@opentui/solid": "0.3.4",
    "fuzzysort": "^3.1.0",
    "jsonc-parser": "^3.3.1",
    "solid-js": "1.9.12",
    "zod": "^4.4.3"
  }
}
