{
  "name": "oc2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "oc2": "./src/index.ts"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c oxlint.json src test",
    "format": "prettier --write .",
    "diagnostics": "bun run typecheck && bun run lint && bun test"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.9",
    "@types/bun": "1.3.13",
    "oxlint": "1.60.0",
    "prettier": "3.6.2",
    "typescript": "5.8.2"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "zod": "^4.4.3"
  }
}
