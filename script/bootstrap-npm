#!/usr/bin/env bash

set -euo pipefail

REPO="panwar-stack/oc2"
RUN_ID="29291612131"
SOURCE="26fad8936424da2855639d6728ab9e4bb39646a1"
BOOTSTRAP_VERSION="0.0.0-bootstrap.0"
BOOTSTRAP_TAG="bootstrap"
RELEASE_VERSION="0.0.2"
REGISTRY="https://registry.npmjs.org"

PACKAGES=(
  oc2-darwin-arm64
  oc2-darwin-x64
  oc2-darwin-x64-baseline
  oc2-linux-arm64
  oc2-linux-arm64-musl
  oc2-linux-x64
  oc2-linux-x64-baseline
  oc2-linux-x64-baseline-musl
  oc2-linux-x64-musl
  oc2-windows-arm64
  oc2-windows-x64
  oc2-windows-x64-baseline
  oc2-ai
)

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

if [[ "$#" -ne 0 ]]; then
  die "usage: $0"
fi

for command in awk bun curl gh git grep node npm; do
  require_command "$command"
done

node - "$(npm --version)" <<'NODE'
const value = process.argv[2]
const [major, minor] = value.split(".").map(Number)

if (major < 11 || (major === 11 && minor < 15)) {
  throw new Error(`npm >=11.15.0 is required, got ${value}`)
}
NODE

WORK_DIR=$(mktemp -d "${TMPDIR:-/tmp}/oc2-npm-bootstrap.XXXXXX")
REPO_DIR="$WORK_DIR/repo"
NPMRC="$WORK_DIR/npmrc"
LOGGED_IN=0

cleanup_credentials() {
  local fail_closed="${1:-0}"

  if [[ "$LOGGED_IN" == "1" ]]; then
    if ! NPM_CONFIG_USERCONFIG="$NPMRC" npm logout --registry="$REGISTRY" >/dev/null 2>&1; then
      if [[ "$fail_closed" == "1" ]]; then
        return 1
      fi
      printf 'Warning: npm logout failed; revoke the active npm credential manually.\n' >&2
    fi
    LOGGED_IN=0
  fi

  rm -f "$NPMRC"
}

cleanup() {
  cleanup_credentials
  if [[ -n "${WORK_DIR:-}" ]]; then
    rm -rf "$WORK_DIR"
  fi
}

trap cleanup EXIT
trap 'exit 130' HUP INT TERM

gh auth status
printf 'Bun %s, Node %s, npm %s\n' "$(bun --version)" "$(node --version)" "$(npm --version)"

[[ "$(gh release view "v$RELEASE_VERSION" --repo "$REPO" --json targetCommitish --jq .targetCommitish)" == "$SOURCE" ]] \
  || die "v$RELEASE_VERSION does not target $SOURCE"
[[ "$(gh release view "v$RELEASE_VERSION" --repo "$REPO" --json isDraft --jq .isDraft)" == "true" ]] \
  || die "v$RELEASE_VERSION is not a draft"

gh repo clone "$REPO" "$REPO_DIR"
git -C "$REPO_DIR" checkout --detach "$SOURCE"
[[ "$(git -C "$REPO_DIR" rev-parse HEAD)" == "$SOURCE" ]] || die "checkout does not match $SOURCE"

cd "$REPO_DIR"
bun install --frozen-lockfile

unset OC2_RELEASE OC2_BUMP GH_TOKEN GH_REPO

OC2_VERSION="$BOOTSTRAP_VERSION" \
OC2_CHANNEL="$BOOTSTRAP_TAG" \
bun ./packages/opencode/script/build.ts

# The JavaScript template expression must be evaluated by Bun, not Bash.
# shellcheck disable=SC2016
OC2_VERSION="$BOOTSTRAP_VERSION" bun -e '
import { validateNativePackages } from "./packages/opencode/script/release-artifacts.ts"

const version = await validateNativePackages("./packages/opencode/dist")
if (version !== process.env.OC2_VERSION) {
  throw new Error(`artifact version ${version} does not match ${process.env.OC2_VERSION}`)
}
'

umask 077
printf 'registry=%s\n' "$REGISTRY" >"$NPMRC"
chmod 600 "$NPMRC"
export NPM_CONFIG_USERCONFIG="$NPMRC"
export NPM_CONFIG_REGISTRY="$REGISTRY"

printf '\nCreate a short-lived granular npm token with read/write package access and Bypass 2FA enabled.\n'
unset NPM_BOOTSTRAP_TOKEN
if ! IFS= read -r -s -p 'Paste the bootstrap npm token: ' NPM_BOOTSTRAP_TOKEN; then
  printf '\n'
  die "could not read the bootstrap npm token"
fi
printf '\n'
[[ -n "$NPM_BOOTSTRAP_TOKEN" ]] || die "bootstrap npm token cannot be empty"

LOGGED_IN=1
printf '//registry.npmjs.org/:_authToken=%s\n' "$NPM_BOOTSTRAP_TOKEN" >>"$NPMRC"
unset NPM_BOOTSTRAP_TOKEN

NPM_USER=$(npm whoami --registry="$REGISTRY")
printf 'Authenticated to npm as %s\n' "$NPM_USER"

for package in "${PACKAGES[@]}"; do
  if current=$(npm view "$package@$BOOTSTRAP_VERSION" version --registry="$REGISTRY" 2>/dev/null); then
    [[ "$current" == "$BOOTSTRAP_VERSION" ]] || die "unexpected version for $package: $current"
    npm owner ls "$package" --registry="$REGISTRY" \
      | awk '{print $1}' \
      | grep -Fx "$NPM_USER" >/dev/null \
      || die "$NPM_USER is not an owner of $package"
    printf 'Resuming existing %s@%s\n' "$package" "$BOOTSTRAP_VERSION"
    continue
  fi

  status=$(curl -sS -o /dev/null -w '%{http_code}' "$REGISTRY/$package")
  [[ "$status" == "404" ]] || die "$package already exists or the registry returned HTTP $status"
done

printf '\nThis will publicly publish all 13 packages as %s under the %s tag.\n' "$BOOTSTRAP_VERSION" "$BOOTSTRAP_TAG"
read -r -p 'Type publish-bootstrap to continue: ' confirmation
[[ "$confirmation" == "publish-bootstrap" ]] || die "publication cancelled"

OC2_VERSION="$BOOTSTRAP_VERSION" \
OC2_CHANNEL="$BOOTSTRAP_TAG" \
NPM_CONFIG_PROVENANCE=false \
bun ./packages/opencode/script/publish.ts

for package in "${PACKAGES[@]}"; do
  [[ "$(npm view "$package@$BOOTSTRAP_VERSION" version --registry="$REGISTRY")" == "$BOOTSTRAP_VERSION" ]] \
    || die "could not verify $package@$BOOTSTRAP_VERSION"
  [[ "$(npm view "$package" "dist-tags.$BOOTSTRAP_TAG" --registry="$REGISTRY")" == "$BOOTSTRAP_VERSION" ]] \
    || die "could not verify the $BOOTSTRAP_TAG tag for $package"
  npm owner ls "$package" --registry="$REGISTRY"
done

cleanup_credentials 1 || die "could not log out the bootstrap npm token"
printf 'registry=%s\n' "$REGISTRY" >"$NPMRC"
chmod 600 "$NPMRC"

LOGGED_IN=1
npm login --auth-type=web --registry="$REGISTRY"

for package in "${PACKAGES[@]}"; do
  trust=$(npm trust list "$package" --json --registry="$REGISTRY")
  if [[ -z "$trust" ]]; then
    npm trust github "$package" \
      --repo "$REPO" \
      --file publish.yml \
      --allow-publish \
      --yes \
      --registry="$REGISTRY"
    sleep 2
  fi

  trust=$(npm trust list "$package" --json --registry="$REGISTRY")
  node - "$trust" <<'NODE'
const value = JSON.parse(process.argv[2])
const valid =
  value.type === "github" &&
  value.repository === "panwar-stack/oc2" &&
  value.file === "publish.yml" &&
  !("environment" in value) &&
  Array.isArray(value.permissions) &&
  value.permissions.length === 1 &&
  value.permissions[0] === "createPackage"

if (!valid) {
  throw new Error(`unexpected trusted-publisher configuration: ${process.argv[2]}`)
}
NODE
  printf 'Trusted publishing configured for %s\n' "$package"
done

cleanup_credentials 1 || die "could not log out the npm web session"
rm -rf "$WORK_DIR"
WORK_DIR=""
unset NPM_CONFIG_USERCONFIG NPM_CONFIG_REGISTRY

printf 'Rerunning GitHub workflow %s\n' "$RUN_ID"
gh run rerun "$RUN_ID" --repo "$REPO"

if ! gh run watch "$RUN_ID" --repo "$REPO" --exit-status; then
  gh run view "$RUN_ID" --repo "$REPO" --log-failed
  exit 1
fi

for package in "${PACKAGES[@]}"; do
  [[ "$(npm view "$package@$RELEASE_VERSION" version --registry="$REGISTRY")" == "$RELEASE_VERSION" ]] \
    || die "could not verify $package@$RELEASE_VERSION"
  [[ "$(npm view "$package" dist-tags.latest --registry="$REGISTRY")" == "$RELEASE_VERSION" ]] \
    || die "could not verify the latest tag for $package"
  printf 'Verified %s@%s\n' "$package" "$RELEASE_VERSION"
done

[[ "$(gh release view "v$RELEASE_VERSION" --repo "$REPO" --json isDraft --jq .isDraft)" == "false" ]] \
  || die "v$RELEASE_VERSION is still a draft"

gh release view "v$RELEASE_VERSION" \
  --repo "$REPO" \
  --json tagName,targetCommitish,isDraft,url

printf 'Bootstrap and OIDC release completed successfully.\n'
