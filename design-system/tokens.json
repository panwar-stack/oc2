      "variable":   { "dark": "#E8EBF0", "light": "#161B24", "web": "--v2-syntax-variable",   "tui": "syntaxVariable" },
      "string":     { "dark": "#43B26F", "light": "#1C6E40", "web": "--v2-syntax-string",     "tui": "syntaxString" },
