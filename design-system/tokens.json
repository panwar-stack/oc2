    },
    "diff": {
      "added":               { "dark": "#43B26F", "light": "#1C6E40", "web": "--v2-diff-added",                 "tui": "diffAdded" },
      "removed":             { "dark": "#E5534B", "light": "#BE3830", "web": "--v2-diff-removed",               "tui": "diffRemoved" },
      "context":             { "dark": "#9AA4B2", "light": "#525E70", "web": "--v2-diff-context",               "tui": "diffContext" },
      "hunk-header":         { "dark": "#9AA4B2", "light": "#525E70", "web": "--v2-diff-hunk-header",           "tui": "diffHunkHeader" },
      "highlight-added":     { "dark": "#85CDA1", "light": "#144D2D", "web": "--v2-diff-highlight-added",       "tui": "diffHighlightAdded" },
      "highlight-removed":   { "dark": "#EE8F8A", "light": "#852722", "web": "--v2-diff-highlight-removed",     "tui": "diffHighlightRemoved" },
      "added-bg":            { "dark": "#101E1B", "light": "#E4EFE9", "web": "--v2-diff-added-bg",              "tui": "diffAddedBg" },
      "removed-bg":          { "dark": "#201418", "light": "#F9E8E7", "web": "--v2-diff-removed-bg",            "tui": "diffRemovedBg" },
      "context-bg":          { "dark": "#0F131A", "light": "#F3F5F9", "web": "--v2-diff-context-bg",            "tui": "diffContextBg" },
      "line-number":         { "dark": "#5C6675", "light": "#67717F", "web": "--v2-diff-line-number",           "tui": "diffLineNumber" },
      "added-line-number-bg": { "dark": "#152E25", "light": "#CEE2D6", "web": "--v2-diff-added-line-number-bg", "tui": "diffAddedLineNumberBg" },
      "removed-line-number-bg": { "dark": "#361B1D", "light": "#F3D4D2", "web": "--v2-diff-removed-line-number-bg", "tui": "diffRemovedLineNumberBg" }
    },
    "terminal": {
      "notes": "Proposed 16-color ANSI palette for the web terminal — an addition for future full ANSI theming, not a description of current code. Current code: packages/app/src/components/terminal.tsx uses ghostty-web; getTerminalColors() returns bg/fg/cursor/selection from the active theme, with DEFAULT_TERMINAL_COLORS (4 hardcoded colors per mode) as fallback. Dark brights are hue + 35% white; light brights are hue - 30% black.",
      "dark":  { "0-black": "#0A0D12", "1-red": "#E5534B", "2-green": "#43B26F", "3-yellow": "#E8A33D", "4-blue": "#5B93FF", "5-magenta": "#A78BFA", "6-cyan": "#3EBDB4", "7-white": "#9AA4B2", "8-bright-black": "#5C6675", "9-bright-red": "#EE8F8A", "10-bright-green": "#85CDA1", "11-bright-yellow": "#F0C381", "12-bright-blue": "#94B9FF", "13-bright-magenta": "#C6B4FC", "14-bright-cyan": "#82D4CE", "15-bright-white": "#E8EBF0" },
      "light": { "0-black": "#161B24", "1-red": "#BE3830", "2-green": "#1C6E40", "3-yellow": "#8F5A0E", "4-blue": "#2E5BB8", "5-magenta": "#6D4FC2", "6-cyan": "#0C6E67", "7-white": "#E9EDF4", "8-bright-black": "#67717F", "9-bright-red": "#852722", "10-bright-green": "#144D2D", "11-bright-yellow": "#643F0A", "12-bright-blue": "#204081", "13-bright-magenta": "#4C3788", "14-bright-cyan": "#084D48", "15-bright-white": "#FFFFFF" },
      "web": "--v2-terminal-ansi-*"
    },
    "avatar": {
      "recipe": "avatar bg = hue pill tint, border = hue 35% border, fg = hue; matches --v2-avatar-bg-*/border-* structure",
      "ramp": ["blue", "teal", "purple", "green", "amber", "red", "cyan", "pink"],
      "web": "--v2-avatar-bg-{name} / --v2-avatar-border-{name} / --v2-avatar-fg"
    },
    "agent-ramp": {
      "order": ["blue", "teal", "purple", "green", "amber", "red", "cyan", "pink"],
      "assignment": "stable by name: index = hash(agent-name) mod 8. Replaces the TUI's order-based color cycle so an agent keeps its color across sessions and member reordering.",
      "dark":  { "blue": "#5B93FF", "teal": "#3EBDB4", "purple": "#A78BFA", "green": "#43B26F", "amber": "#E8A33D", "red": "#E5534B", "cyan": "#4FC3E8", "pink": "#F27BA7" },
      "light": { "blue": "#2E5BB8", "teal": "#0C6E67", "purple": "#6D4FC2", "green": "#1C6E40", "amber": "#8F5A0E", "red": "#BE3830", "cyan": "#0B6B84", "pink": "#B53E71" },
      "web": "--v2-agent-{n}",
      "tui": "proposed (see mapping/tui.md Proposed additions)"
    }
  },

  "ansi": {
    "file": "tokens/ansi.json",
    "hue-ansi256-dark": { "blue": 69, "amber": 179, "teal": 73, "purple": 141, "green": 71, "red": 167 },
    "hue-ansi256-light": { "blue": 25, "amber": 94, "teal": 23, "purple": 61, "green": 23, "red": 131 },
    "hue-ansi16": { "blue": 4, "amber": 3, "teal": 6, "purple": 5, "green": 2, "red": 1 },
    "neutral-ansi256-dark": { "bg-0": 233, "bg-1": 233, "bg-2": 234, "bg-3": 235, "border": 236, "border-strong": 237, "text-1": 255, "text-2": 248, "text-3": 242 },
    "degradation": "bg-0 and bg-1 both round to 233; use the recommended spread 233/234/235/236/237 to keep layer separation. Light green and teal both round to 23 in 256-color mode; disambiguate by glyph, not hue."
  },

  "proposed": {
    "notes": "Tokens in this section do not exist in the current TUI Theme type or web v2 var list. They are specified here and exactly once in the Proposed additions section of mapping/tui.md or mapping/web.md. Component specs may reference them only via these names.",
    "tui": [
      { "token": "scrim", "value-dark": "rgba(0,0,0,.59)", "value-light": "rgba(22,27,36,.45)", "replaces": "hardcoded RGBA.fromInts(0,0,0,150) in ui/dialog.tsx" },
      { "token": "scrimLight", "value-dark": "rgba(0,0,0,.27)", "value-light": "rgba(22,27,36,.22)", "replaces": "hardcoded RGBA.fromInts(0,0,0,70) in routes/session/index.tsx" },
      { "token": "agentColorRamp", "value": "domain.agent-ramp", "fallback": "existing 7-color cycle in packages/tui context/local.tsx: [secondary, accent, success, warning, primary, error, info]", "replaces": "order-based agent color cycle (packages/tui context/local.tsx)" },
      { "token": "diffSplitCols", "value": 120, "replaces": "literal 120 in session-v2.tsx / routes/session/index.tsx" },
      { "token": "textFaint", "value-dark": "#5C6675", "value-light": "#67717F", "replaces": "inline faint-text hexes" }
    ],
    "web": [
      { "token": "--v2-state-fg-thinking / --v2-state-bg-thinking / --v2-state-border-thinking", "why": "v2 has warning but not the thinking/process state" },
      { "token": "--v2-state-fg-decision / --v2-state-bg-decision / --v2-state-border-decision / --v2-state-fill-decision", "why": "v2 has no decision/needs-you state" },
      { "token": "--v2-state-fg-tool / --v2-state-bg-tool / --v2-state-border-tool", "why": "v2 has no tool/infra state" },
      { "token": "--v2-focus-ring, --v2-shadow-*, --v2-z-*, --v2-duration-*, --v2-ease-*, --v2-space-*, --v2-radius-*, --v2-font-size-*, --v2-syntax-*, --v2-markdown-*, --v2-diff-*, --v2-terminal-ansi-*, --v2-agent-*", "why": "structural and domain tokens not present in the current v2 stylesheets; defined in tokens/web.css" }
    ]
  }
