  "contrast-pairs": [
    { "fg": "text.primary",   "bg": "surface.app", "dark": 16.28, "light": 17.26, "wcag": "AAA", "use": "body content" },
    { "fg": "text.secondary", "bg": "surface.app", "dark": 7.72,  "light": 6.58,  "wcag": "AAA", "use": "meta, summaries" },
    { "fg": "text.tertiary",  "bg": "surface.app", "dark": 3.35,  "light": 4.95,  "wcag": "fail-dark / AA-light", "use": "non-essential hints only in dark; see guidelines/accessibility.md" },
    { "fg": "state.thinking.fg", "bg": "surface.app", "dark": 9.02, "light": 5.77, "wcag": "AAA/AA", "use": "thinking rows, timers" },
    { "fg": "state.tool.fg",     "bg": "surface.app", "dark": 8.47, "light": 6.10, "wcag": "AAA/AA", "use": "tool names" },
    { "fg": "state.decision.fg", "bg": "surface.app", "dark": 7.15, "light": 5.92, "wcag": "AA", "use": "decision UI" },
    { "fg": "state.success.fg",  "bg": "surface.app", "dark": 7.26, "light": 6.26, "wcag": "AA", "use": "success states" },
    { "fg": "state.danger.fg",   "bg": "surface.app", "dark": 5.25, "light": 5.53, "wcag": "AA", "use": "error states" },
    { "fg": "text.accent",       "bg": "surface.app", "dark": 6.54, "light": 6.35, "wcag": "AA", "use": "links, accents" },
    { "fg": "accent.on-strong",  "bg": "accent.primary.fill", "dark": 6.35, "light": 6.35, "wcag": "AA", "use": "Send button label" },
    { "fg": "accent.on",         "bg": "accent.decision.fill", "dark": 7.15, "light": 5.92, "wcag": "AA", "use": "decision confirm label (replaces mock one-off #17122B)" },
    { "fg": "accent.on",         "bg": "hue.blue",   "dark": 6.54, "light": null, "wcag": "AA", "use": "text on primary selection fill (dark); never white on blue (2.97:1)" },
    { "fg": "state.danger.fg",   "bg": "primitives.tint.{dark,light}.red-pill", "dark": 4.60, "light": 4.67, "wcag": "AA", "use": "worst-case pill pair; all other pills 4.67-7.3:1" }
  ],

  "type": {
    "families": {
      "mono":    { "stack": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace", "web": "--v2-font-family-mono", "use": "product default; TUI is always mono" },
      "sans":    { "stack": "'Inter', -apple-system, 'Segoe UI', sans-serif",                        "web": "--v2-font-family-sans", "use": "web prose paragraphs, marketing surfaces" },
      "display": { "stack": "'Space Grotesk', 'Inter', sans-serif",                                  "web": "--v2-font-family-display", "use": "web-only large headings (welcome hero); never in TUI" }
    },
    "scale": [
      { "token": "type.micro",  "px": 9.5,  "line-height": 1.2,  "weight": 700, "tracking": ".1em",  "transform": "uppercase", "web": "--v2-font-size-micro",  "use": "badges, counts, severity pills, section micro-labels" },
      { "token": "type.label",  "px": 10,   "line-height": 1.2,  "weight": 700, "tracking": ".1em",  "transform": "uppercase", "web": "--v2-font-size-label",  "use": "section headers, aggregates (RECENT SESSIONS, WORKING · 3)" },
      { "token": "type.meta",   "px": 10.5, "line-height": 1.45, "weight": 400, "tracking": "0",     "transform": "none",       "web": "--v2-font-size-meta",   "use": "status bar, turn footer, key-hint descriptions" },
      { "token": "type.small",  "px": 11.5, "line-height": 1.45, "weight": 400, "tracking": "0",     "transform": "none",       "web": "--v2-font-size-small",  "use": "tool rows, member rows, todo rows" },
      { "token": "type.body",   "px": 12.5, "line-height": 1.62, "weight": 400, "tracking": "0",     "transform": "none",       "web": "--v2-font-size-body",   "use": "product default; timeline prose, composer input (13px acceptable for web input)" },
      { "token": "type.title",  "px": 13,   "line-height": 1.45, "weight": 700, "tracking": "0",     "transform": "none",       "web": "--v2-font-size-title",  "use": "board titles, dialog titles" },
      { "token": "type.display", "px": 14,  "line-height": 1.3,  "weight": 700, "tracking": "-.01em", "transform": "none",      "web": "--v2-font-size-display", "use": "welcome brand line; largest product size" }
    ],
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "rules": [
      "Hierarchy comes from weight + text-1/2/3 color steps first; size changes only within this scale, never below 9.5px or above 14px in product chrome.",
      "Resolves the mock's 'one size' principle vs the measured 9-14px range (9px pills, 13.5px, 14px brand): body is one size (12.5px); the 7-step scale is the sanctioned exception budget.",
      "TUI renders one cell size; the scale maps to weight/color/glyph channels there (see guidelines/typography.md)."
    ]
  },

  "spacing": {
    "grid": { "ch-px": 7.5, "line-px": 20.25, "basis": "1ch = 0.6em at 12.5px JetBrains Mono = 7.5px; 1 line = 12.5px x 1.62 = 20.25px" },
    "scale": { "space-1": 2, "space-2": 4, "space-3": 6, "space-4": 8, "space-5": 10, "space-6": 12, "space-7": 14, "space-8": 16, "space-9": 20, "space-10": 24, "space-11": 32 },
    "recipes": {
      "card-padding": "space-4..space-6 vertical (7-12px in mock), space-5..space-7 horizontal (10-14px = ~1.5-2ch; qopt/think-row use 10px)",
      "row-padding": "space-3..space-4 vertical, space-6 horizontal",
      "gaps": "space-4 (8) tight, space-5 (10) default, space-7 (14) loose",
      "section-gap": "space-9..space-11"
    },
    "web": "--v2-space-*"
  },

  "radii": {
    "radius-base":     { "px": 4,  "use": "small boxes, checkboxes" },
    "radius-kbd":      { "px": 5,  "use": "key-hint chips" },
    "radius-chip":     { "px": 6,  "use": "chips, send button, attachment chips, thinking row" },
    "radius-option":   { "px": 7,  "use": "question options, segmented tabs" },
    "radius-group":    { "px": 8,  "use": "tool groups, todo blocks, user messages, recent-session list" },
    "radius-card":     { "px": 9,  "use": "worker cards" },
    "radius-composer": { "px": 10, "use": "composer, question card, swatches" },
    "radius-frame":    { "px": 12, "use": "app frames, dialogs, shots" },
    "radius-pill":     { "px": 99, "use": "pills, gauges, count bubbles" },
    "web": "--v2-radius-*"
  },

  "border": {
    "width-std": 1,
    "width-accent-left": 3,
    "width-checkbox": 1.5,
    "width-kbd-bottom": 2,
    "notes": "User messages use a 3px left accent border (border-left: 3px solid hue.blue). Key chips use a 2px bottom border for the pressed-key look. Everything else is 1px."
  },

  "shadow": {
    "frame":      { "dark": "0 18px 48px rgba(10,13,18,.28), 0 2px 8px rgba(10,13,18,.2)", "light": "0 18px 48px rgba(23,27,34,.14), 0 2px 8px rgba(23,27,34,.08)", "web": "--v2-shadow-frame", "use": "app frame, dialogs" },
    "popover":    { "dark": "0 8px 24px rgba(10,13,18,.24)",  "light": "0 8px 24px rgba(23,27,34,.12)",  "web": "--v2-shadow-popover", "use": "select lists, menus, tooltips" },
    "dialog":     { "dark": "0 24px 64px rgba(10,13,18,.45), 0 4px 16px rgba(10,13,18,.3)", "light": "0 24px 64px rgba(23,27,34,.22), 0 4px 16px rgba(23,27,34,.12)", "web": "--v2-shadow-dialog", "use": "modal dialogs over scrim" },
    "focus-ring": { "dark": "0 0 0 3px rgba(91,147,255,.18)", "light": "0 0 0 3px rgba(46,91,184,.18)", "web": "--v2-shadow-focus", "use": "focus ring; pair with border.active" },
    "none": "cards and groups are border-defined; shadows are reserved for floating layers only"
  },

  "motion": {
    "duration": { "instant": 0, "fast": 80, "base": 140, "slow": 220, "unit": "ms", "web": "--v2-duration-*" },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "entrance": "cubic-bezier(0, 0, 0.2, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)",
      "web": "--v2-ease-*"
    },
    "caret": { "period-ms": 1100, "technique": "steps(1)", "keyframe": "50% { opacity: 0 }", "web": "--v2-duration-caret" },
    "spinner": { "frames": ["◐", "◑", "◓"], "frame-ms": 200, "cycle-ms": 600, "notes": "3-frame glyph cycle; TUI swaps glyph per frame, web may rotate or swap" },
    "usage": {
      "fast": "hover tint, chip press",
      "base": "focus ring, border color, row highlight",
      "slow": "expand/collapse, dialog enter/exit, toast slide"
    },
    "reduced-motion": {
      "rule": "prefers-reduced-motion: reduce -> all durations become 0.01ms; caret stops blinking (stays visible); spinner freezes on ◐ with adjacent text label carrying the state; no smooth scrolling.",
      "web": "@media (prefers-reduced-motion: reduce) block in tokens/web.css",
      "tui": "respect OC2_TUI_REDUCE_MOTION / terminal equivalent: freeze spinner on ◐, keep caret static"
    }
  },

  "z-index": {
    "web": { "base": 0, "annotation": 5, "raised": 10, "sticky-nav": 50, "scrim": 100, "dialog": 110, "popover": 120, "select": 120, "toast": 130, "tooltip": 140, "css": "--v2-z-*" },
    "tui": { "dialog": 3000, "notes": "existing OpenTUI convention; toasts render below dialogs; keep TUI values as-is" },
    "notes": "Mock defines annotation 5 and sticky nav 50; the 100+ floating stack is derived for the web product (gap resolution)."
  },

  "glyph": {
    "pending":      { "char": "○", "color": "text.tertiary", "meaning": "pending / idle / queued, not started" },
    "running":      { "char": "◐", "frames": ["◐", "◑", "◓"], "color": "state.thinking.fg", "meaning": "running / active right now" },
    "done":         { "char": "✓", "color": "state.success.fg", "meaning": "done / healthy" },
    "failed":       { "char": "✕", "color": "state.danger.fg", "meaning": "failed / error" },
    "needs-you":    { "char": "▲", "color": "state.decision.fg", "meaning": "question, approval, plan review waiting" },
    "collapsed":    { "char": "▸", "color": "text.secondary", "meaning": "collapsed / expandable" },
    "expanded":     { "char": "▾", "color": "text.secondary", "meaning": "expanded / collapsible" },
    "live":         { "char": "●", "color": "state.success.fg", "meaning": "live / service up / current item" },
    "mailbox":      { "char": "✉", "color": "state.tool.fg", "meaning": "team mailbox, unread messages" },
    "tool-group":   { "char": "⌗", "color": "state.tool.fg", "meaning": "tool-call group header" },
    "attachment":   { "char": "▤", "color": "text.secondary", "meaning": "file attachment" },
    "gauge-full":   { "char": "▰", "color": "context-dependent", "meaning": "filled gauge segment" },
    "gauge-empty":  { "char": "▱", "color": "text.tertiary", "meaning": "empty gauge segment" },
    "brand":        { "char": "›_", "color": "text.primary", "meaning": "OC2 brand mark" },
    "continuation": { "char": "↳", "color": "text.tertiary", "meaning": "child/detail line of a failed or expanded row" },
    "separator":    { "char": "·", "color": "text.tertiary", "meaning": "inline metadata separator" },
    "enter":        { "char": "⏎", "color": "text.tertiary", "meaning": "enter key hint" },
    "notes": "All glyphs render in stock monospace fonts (no Nerd Font required). One glyph = one state, paired with its semantic hue; never recolor a glyph to a different hue family."
  },

  "thresholds": {
    "context-gauge": { "amber": 70, "red": 90, "unit": "percent of context window", "notes": "Below 70% gauge uses state.success.fg; >= 70% state.thinking.fg; >= 90% state.danger.fg. Sidebar context section documents 'warns at 70%'." },
    "diff-split": { "tui-cols": 120, "web-px": 880, "notes": "TUI splits diff view when width > 120 cols (existing behavior in packages/tui session routes); web splits when the diff container is >= 880px (120ch x 7.5px - padding)." }
  },

  "breakpoints": {
    "compact": { "max-px": 759, "behavior": "single column; sidebar hidden behind ctrl+b overlay; team board 1 column" },
    "medium":  { "min-px": 760, "max-px": 1099, "behavior": "sidebar toggleable; team board 2 columns" },
    "wide":    { "min-px": 1100, "behavior": "sidebar persistent (34ch = 255px); team board 3 columns" },
    "notes": "760 aligns with the mock's team-board grid collapse; 1100 = timeline (min ~600px) + sidebar (255px) + gutters."
  },

  "layout": {
    "sidebar-width": { "ch": 34, "px": 255 },
    "dialog-widths-cols": [60, 88, 116],
    "timeline-max-ch": 72,
    "app-shell": ["frame-bar (web only)", "main column (timeline | board | tasks)", "sidebar (right, toggleable)", "working-bar (pinned, conditional)", "composer", "status-bar"]
  },

  "component-states": {
    "model": ["idle", "hover", "focus", "active", "selected", "disabled", "loading", "success", "error", "denied", "queued", "working", "needs-you"],
    "rules": {
      "idle": "default surface + border.base + text.primary",
      "hover": "surface.raised (web) or no-op (TUI without mouse); border.strong on interactive chips",
      "focus": "border.active + focus.ring; never color-only",
      "active": "pressed: surface.raised + border.strong",
      "selected": "web: state fill or surface.raised + text.primary + bold; TUI: primary bg + accent.on fg + bold (existing selectedListItemText convention)",
      "disabled": "text.tertiary on surface.bar, no hover, cursor default; keep in tab order only if focusable-disabled is required",
      "loading": "spinner glyph cycling ◐◑◓ + text.secondary label; surface unchanged",
      "success": "glyph.done + state.success.fg; transient (toast) or persistent (row glyph)",
      "error": "glyph.failed + state.danger.fg + state.danger.bg surface when blocking",
      "denied": "strikethrough text + state.danger.fg glyph ✕; permission denials are errors with a denial glyph, not warnings",
      "queued": "glyph.pending + text.secondary + 'queued' label; composer shows dim send button",
      "working": "glyph.running (cycling) + state.thinking.fg + elapsed timer; persistent working-bar",
      "needs-you": "glyph.needs-you + state.decision.fg + decision card anchored above composer"
    }
  },

  "domain": {
    "syntax": {
      "comment":    { "dark": "#5C6675", "light": "#67717F", "web": "--v2-syntax-comment",    "tui": "syntaxComment" },
      "keyword":    { "dark": "#A78BFA", "light": "#6D4FC2", "web": "--v2-syntax-keyword",    "tui": "syntaxKeyword" },
