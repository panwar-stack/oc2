    "state.success.border": { "dark": "#1E4733", "light": "#B1D0BE", "web": "--v2-state-border-success", "tui": "success", "ansi256": 236, "role": "success surface border" },
    "state.danger.fg":     { "dark": "#E5534B", "light": "#BE3830", "web": "--v2-state-fg-danger",     "tui": "error", "ansi256": 167, "role": "failed, denied, over-limit" },
    "state.danger.bg":     { "dark": "#171115", "light": "#FCF3F3", "web": "--v2-state-bg-danger",     "tui": "error", "ansi256": 233, "role": "error surface" },
