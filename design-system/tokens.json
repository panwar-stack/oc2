{
  "meta": {
    "name": "oc2-design-system",
    "version": "1.0.0",
    "description": "Master token set for the OC2 product UI (web + TUI), derived from the oc2-redesign hi-fi mocks. One hue = one meaning; text says what, color says how it's going, position says where it belongs.",
    "generated": "2026-07-17",
    "sources": [
      "oc2-redesign/index.html (hi-fi mocks M1-M6, principles, token swatches)",
      "oc2-redesign/assets/shot-1..5.png (shipped before UI)",
      "packages/ui/src/v2/styles/theme.css + colors.css (--v2-* semantics)",
      "packages/ui/src/styles/theme.css (legacy 564 unprefixed vars)",
      "packages/tui/src/theme/index.ts (Theme type, ThemeJson, resolveTheme)",
      "packages/tui/src/theme/assets/oc2.json (house theme conventions)"
    ],
    "modes": ["dark", "light"],
    "default-mode": "dark",
    "conventions": {
      "token-paths": "kebab-case dotted paths, e.g. state.thinking.fg",
      "web": "CSS custom properties under tokens/web.css, switched via [data-color-scheme]",
      "tui": "ThemeJson-shaped tokens/tui.theme.json, resolved by resolveTheme(json, mode)",
      "ansi": "tokens/ansi.json holds ANSI-16/256 fallbacks for limited terminals"
    }
  },

  "primitives": {
    "neutral": {
      "dark": {
        "bg-0": "#0A0D12",
        "bg-1": "#0F131A",
        "bg-2": "#151B25",
        "bg-3": "#1C2431",
        "border": "#232C3B",
        "border-strong": "#2E3949",
        "border-subtle": "#1C2330",
        "text-1": "#E8EBF0",
        "text-2": "#9AA4B2",
        "text-3": "#5C6675"
      },
      "light": {
        "bg-0": "#FFFFFF",
        "bg-1": "#F3F5F9",
        "bg-2": "#E9EDF4",
        "bg-3": "#DCE3EE",
        "border": "#C9D2E0",
        "border-strong": "#AEB9CB",
        "border-subtle": "#D9DFEA",
        "text-1": "#161B24",
        "text-2": "#525E70",
        "text-3": "#67717F"
      },
      "notes": {
        "border-subtle": "Derived (not in mocks): midpoint of bg-2 and border, for hairline separators. Dark #1C2330, light #D9DFEA.",
        "light-derivation": "No product light theme exists in the mocks. Light ramp keeps the blue-grey hue family (~218 deg) and inverts lightness: bg-0 white, each layer step ~5% darker. Text steps tuned to keep text-2 >= 6.5:1 and text-3 >= 4.9:1 on bg-0 (WCAG AA). See guidelines/accessibility.md."
      }
    },
    "hue": {
      "blue":   { "dark": "#5B93FF", "light": "#2E5BB8", "strong-dark": "#2E5BB8", "strong-light": "#254C99", "bright-dark": "#94B9FF", "ansi256": 69,  "ansi16": 4,  "meaning": "you / primary / focus / informational" },
      "amber":  { "dark": "#E8A33D", "light": "#8F5A0E", "strong-dark": "#C77F1F", "strong-light": "#6F430A", "bright-dark": "#F0C381", "ansi256": 179, "ansi16": 3,  "meaning": "thinking / active work / warning severity" },
      "teal":   { "dark": "#3EBDB4", "light": "#0C6E67", "strong-dark": "#2FA39B", "strong-light": "#085754", "bright-dark": "#82D4CE", "ansi256": 73,  "ansi16": 6,  "meaning": "tools / team infrastructure" },
      "purple": { "dark": "#A78BFA", "light": "#6D4FC2", "strong-dark": "#8B6FF0", "strong-light": "#573DA6", "bright-dark": "#C6B4FC", "ansi256": 141, "ansi16": 5,  "meaning": "decision needed (questions, approvals, plans)" },
      "green":  { "dark": "#43B26F", "light": "#1C6E40", "strong-dark": "#379A5E", "strong-light": "#155832", "bright-dark": "#85CDA1", "ansi256": 71,  "ansi16": 2,  "meaning": "success / done / healthy" },
      "red":    { "dark": "#E5534B", "light": "#BE3830", "strong-dark": "#C94338", "strong-light": "#9E2C25", "bright-dark": "#EE8F8A", "ansi256": 167, "ansi16": 1,  "meaning": "failure / error / denied / over-limit" },
      "cyan":   { "dark": "#4FC3E8", "light": "#0B6B84", "bright-dark": "#93DAF2", "ansi256": 74,  "ansi16": 14, "meaning": "agent ramp only (not a semantic state hue)" },
      "pink":   { "dark": "#F27BA7", "light": "#B53E71", "bright-dark": "#F8ABC6", "ansi256": 211, "ansi16": 13, "meaning": "agent ramp only (not a semantic state hue)" },
      "notes": {
        "strong": "strong-dark/strong-light are filled-button grades of the hue. Mock defines button blue #2E5BB8 (= strong-dark of blue).",
        "bright-dark": "Hue mixed 35% toward white; used for ANSI bright variants and diff intra-line highlights. Hand-tuned exceptions: bright-dark cyan #93DAF2 and pink #F8ABC6 are mock values, not exact 35% blends.",
        "light-hue-rule": "Light hues are darkened until they reach >= 4.5:1 on bg-0 #FFFFFF and on their own 12% pill tint; identity (hue angle) is preserved."
      }
    },
    "tint": {
      "recipe": "Tints are hue-alpha blends precomputed over the mode bg-0. Dark pills use 14% hue; dark alert surfaces 5-7% bg with 18-40% border (per mock; 40% appears on live/focus accents such as qopt.foc and wcard.live). Light pills use 12% hue; light alert surfaces 6% bg with 25-35% border. Hand-tuned exceptions kept from the mock: light amber/teal/green/red pills are ~10.8-11.5% blends (not 12%), light amber-surface is ~5.5% (not 6%), and dark amber-surface-7 #1C1A14 deviates from the 7% recipe output #1A1815.",
      "dark": {
        "blue-pill": "#152033", "blue-surface": "#0F1520", "blue-border": "#263C65",
        "amber-pill": "#292218", "amber-surface": "#171615", "amber-surface-7": "#1C1A14", "amber-border": "#584221", "amber-border-25": "#42331D",
        "teal-pill": "#112629", "teal-surface": "#0D181C", "teal-border": "#1C4B4B",
        "purple-pill": "#201F32", "purple-surface": "#131520", "purple-grad-top": "#151622", "purple-grad-bot": "#0D1017", "purple-foot": "#10121B", "purple-focus": "#1D1C2E", "purple-border": "#413963", "purple-border-18": "#26243C",
        "green-pill": "#12241F", "green-surface": "#0D1718", "green-border": "#1E4733",
        "red-pill": "#29171A", "red-surface": "#171115", "red-border": "#572626"
      },
      "light": {
        "blue-pill": "#E6EBF6", "blue-surface": "#F2F5FB", "blue-border": "#B6C6E6",
        "amber-pill": "#F3ECE2", "amber-surface": "#F9F6F1", "amber-border": "#DCC8AB",
        "teal-pill": "#E2EFEE", "teal-surface": "#F1F7F7", "teal-border": "#ABD1CE",
        "purple-pill": "#EDEAF8", "purple-surface": "#F6F4FB", "purple-border": "#CCC1EA",
        "green-pill": "#E4EFE9", "green-surface": "#F2F7F4", "green-border": "#B1D0BE",
        "red-pill": "#F9E8E7", "red-surface": "#FCF3F3", "red-border": "#ECBBB8"
      }
    },
    "on-accent": {
      "dark": "#0A0D12",
      "light": "#FFFFFF",
      "on-strong": "#FFFFFF",
      "notes": "Text/icon color drawn on a filled hue. Dark mode: fills are bright (blue/amber/teal/purple/green), so on-accent = bg-0 #0A0D12 (contrast 6.5-9:1). On strong fills (button blue #2E5BB8 dark, all light-mode fills) on-accent = white (5.5-6.4:1). This replaces the mock's one-off purple confirm text #17122B: use on-accent instead."
    }
  },

  "semantic": {
