    "surface.bar":     { "dark": "#0F131A", "light": "#F3F5F9", "web": "--v2-background-bg-layer-01", "tui": "backgroundPanel", "ansi256": 233, "role": "status bar, frame bar, group headers, composer footer" },
    "surface.card":    { "dark": "#151B25", "light": "#E9EDF4", "web": "--v2-background-bg-layer-02", "tui": "backgroundElement", "ansi256": 234, "role": "cards, composer, chips, menus" },
    "surface.raised":  { "dark": "#1C2431", "light": "#DCE3EE", "web": "--v2-background-bg-layer-03", "tui": "backgroundMenu",    "ansi256": 235, "role": "hover/active rows, pressed chips, floating menus" },
    "text.primary":    { "dark": "#E8EBF0", "light": "#161B24", "web": "--v2-text-text-base",   "tui": "text",      "ansi256": 255, "role": "content text; 16.3:1 dark, 17.3:1 light" },
    "text.secondary":  { "dark": "#9AA4B2", "light": "#525E70", "web": "--v2-text-text-muted",  "tui": "textMuted", "ansi256": 248, "role": "meta text, summaries; 7.7:1 dark, 6.6:1 light" },
    "text.tertiary":   { "dark": "#5C6675", "light": "#67717F", "web": "--v2-text-text-faint",  "tui": "textMuted", "ansi256": 242, "role": "faint labels, hints, disabled; 3.4:1 dark (borderline, non-essential text only), 5.0:1 light" },
    "text.accent":     { "dark": "#5B93FF", "light": "#2E5BB8", "web": "--v2-text-text-accent", "tui": "primary",   "ansi256": 69,  "role": "links, active agent, user-affordance text" },
    "border.base":     { "dark": "#232C3B", "light": "#C9D2E0", "web": "--v2-border-border-base",   "tui": "borderSubtle", "ansi256": 236, "role": "standard 1px card/frame border" },
    "border.strong":   { "dark": "#2E3949", "light": "#AEB9CB", "web": "--v2-border-border-strong", "tui": "border",       "ansi256": 237, "role": "composer, kbd, active chip border" },
    "border.subtle":   { "dark": "#1C2330", "light": "#D9DFEA", "web": "--v2-border-border-muted",  "tui": "— (no slot; borderSubtle carries border.base)", "ansi256": 235, "role": "hairline separators, turn indentation rails (derived token)" },
    "border.active":   { "dark": "#5B93FF", "light": "#2E5BB8", "web": "--v2-border-border-focus",  "tui": "borderActive", "ansi256": 69,  "role": "focused panel/composer border" },
    "state.thinking.fg":     { "dark": "#E8A33D", "light": "#8F5A0E", "web": "--v2-state-fg-thinking",     "tui": "warning", "ansi256": 179, "role": "reasoning, active work, elapsed time" },
    "state.thinking.bg":     { "dark": "#171615", "light": "#F9F6F1", "web": "--v2-state-bg-thinking",     "tui": "warning", "ansi256": 233, "role": "thinking-row / working-bar surface (6% hue over bg-0)" },
    "state.thinking.border": { "dark": "#584221", "light": "#DCC8AB", "web": "--v2-state-border-thinking", "tui": "warning", "ansi256": 237, "role": "thinking-row / working-bar border (35% hue over bg-0)" },
    "state.tool.fg":     { "dark": "#3EBDB4", "light": "#0C6E67", "web": "--v2-state-fg-tool",     "tui": "secondary", "ansi256": 73, "role": "tool names, mailbox, team infra" },
    "state.tool.bg":     { "dark": "#0D181C", "light": "#F1F7F7", "web": "--v2-state-bg-tool",     "tui": "secondary", "ansi256": 233, "role": "tool pill/group surface" },
    "state.tool.border": { "dark": "#1C4B4B", "light": "#ABD1CE", "web": "--v2-state-border-tool", "tui": "secondary", "ansi256": 236, "role": "tool surface border" },
    "state.decision.fg":     { "dark": "#A78BFA", "light": "#6D4FC2", "web": "--v2-state-fg-decision",     "tui": "accent", "ansi256": 141, "role": "questions, approvals, plan review" },
    "state.decision.bg":     { "dark": "#131520", "light": "#F6F4FB", "web": "--v2-state-bg-decision",     "tui": "accent", "ansi256": 233, "role": "decision card surface" },
