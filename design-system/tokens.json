      "list-item":        { "dark": "#E8EBF0", "light": "#161B24", "web": "--v2-markdown-list-item",         "tui": "markdownListItem" },
      "list-enumeration": { "dark": "#5B93FF", "light": "#2E5BB8", "web": "--v2-markdown-list-enumeration",  "tui": "markdownListEnumeration" },
      "image":            { "dark": "#A78BFA", "light": "#6D4FC2", "web": "--v2-markdown-image",             "tui": "markdownImage" },
